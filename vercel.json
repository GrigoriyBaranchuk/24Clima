{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "installCommand": "git config --global url.\"https://$GH_PAT@github.com/\".insteadOf \"ssh://git@github.com/\" && bun install",
  "crons": [
    {
      "path": "/api/sync-reviews",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/sync-seo",
      "schedule": "0 7 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/sitemap.xml",
      "has": [
        {
          "type": "host",
          "value": "shop.24clima.com"
        }
      ],
      "destination": "https://24clima.com/sitemap.xml",
      "permanent": false
    },
    {
      "source": "/robots.txt",
      "has": [
        {
          "type": "host",
          "value": "shop.24clima.com"
        }
      ],
      "destination": "https://24clima.com/robots.txt",
      "permanent": false
    },
    {
      "source": "/llms.txt",
      "has": [
        {
          "type": "host",
          "value": "shop.24clima.com"
        }
      ],
      "destination": "https://24clima.com/llms.txt",
      "permanent": false
    },
    {
      "source": "/sitemap.xml",
      "has": [
        {
          "type": "host",
          "value": "www.shop.24clima.com"
        }
      ],
      "destination": "https://24clima.com/sitemap.xml",
      "permanent": false
    },
    {
      "source": "/robots.txt",
      "has": [
        {
          "type": "host",
          "value": "www.shop.24clima.com"
        }
      ],
      "destination": "https://24clima.com/robots.txt",
      "permanent": false
    },
    {
      "source": "/llms.txt",
      "has": [
        {
          "type": "host",
          "value": "www.shop.24clima.com"
        }
      ],
      "destination": "https://24clima.com/llms.txt",
      "permanent": false
    },
    {
      "source": "/es",
      "destination": "/",
      "permanent": true,
      "missing": [
        {
          "type": "host",
          "value": "shop.24clima.com"
        },
        {
          "type": "host",
          "value": "www.shop.24clima.com"
        }
      ]
    },
    {
      "source": "/es/",
      "destination": "/",
      "permanent": true,
      "missing": [
        {
          "type": "host",
          "value": "shop.24clima.com"
        },
        {
          "type": "host",
          "value": "www.shop.24clima.com"
        }
      ]
    },
    {
      "source": "/es/:path*",
      "destination": "/:path*",
      "permanent": true,
      "missing": [
        {
          "type": "host",
          "value": "shop.24clima.com"
        },
        {
          "type": "host",
          "value": "www.shop.24clima.com"
        }
      ]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
